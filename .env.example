# ========== Как запустить локально ==========
# 1) Скопируйте этот файл в .env и заполните значения.
# 2) Установите зависимости: npm install
# 3) Запуск: npm run dev — одновременно API (8787) и Vite (5173).
#    Только фронт без API: npm run dev:vite (регистрация/загрузки не заработают без npm run api).
# 4) Проверка API: http://localhost:8787/api/health — {"ok":true,...}
# 5) Сайт: http://localhost:5173

# ========== БАЗА ДАННЫХ (PostgreSQL) ==========
# Для локальной разработки используйте Docker или установите PostgreSQL локально.
# Пример для Docker: docker run --name regdoc-db -e POSTGRES_DB=regdoc -e POSTGRES_USER=regdoc -e POSTGRES_PASSWORD=your_password -p 5432:5432 -d postgres:15
# ВАЖНО: Для Vercel добавьте переменную DATABASE_URL в панели Vercel Project Settings -> Environment Variables
DATABASE_URL=postgresql://regdoc:your_password@localhost:5432/regdoc

# ========== Облако Mail.ru (заявки, файлы) ==========
# Для Vercel эти переменные тоже нужно добавить в Environment Variables
VK_CLOUD_EMAIL=
VK_CLOUD_PASSWORD=

# ========== JWT (обязательно в production, минимум 16 символов) ==========
JWT_SECRET=замените_на_длинную_случайную_строку_минимум_32_символа
JWT_EXPIRES=7d

# Публичный URL фронта (ссылка «подтвердить email» в письме)
FRONTEND_URL=http://localhost:5173

# ========== Почта (опционально) ==========
# Если SMTP_HOST, SMTP_USER и SMTP_PASS заданы — после регистрации уходит письмо,
# вход возможен только после перехода по ссылке из письма.
# Если НЕ задавать SMTP — аккаунт сразу активен (удобно для разработки).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Порт API (должен совпадать с proxy в vite.config.js)
# PORT=8787